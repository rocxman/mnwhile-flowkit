{
  "name": "@vrun-design/mnwhile-flowkit-mcp",
  "version": "0.1.2",
  "mcpName": "io.github.Vrun-design/mnwhile-flowkit-mcp",
  "description": "Local-first Model Context Protocol server for MNWHILE FlowKit — deterministic diagramming tools (validate DSL, templates, icons, viewer links) for Claude Desktop, Cursor, Windsurf, and other MCP clients. No API key, no cloud round-trip.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mnwhile-flowkit",
    "diagram",
    "flowchart",
    "mermaid",
    "claude",
    "cursor",
    "windsurf",
    "local-first"
  ],
  "homepage": "https://github.com/Vrun-design/mnwhile-flowkit#readme",
  "bugs": "https://github.com/Vrun-design/mnwhile-flowkit/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vrun-design/mnwhile-flowkit.git",
    "directory": "mcp-server"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "mnwhile-flowkit-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:icons": "node scripts/build-icon-manifest.mjs",
    "prebuild": "npm run build:icons",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest --config vitest.config.ts --run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pako": "^2.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
