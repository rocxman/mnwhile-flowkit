# =============================================================================
# MNWHILE FlowKit — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the keys you need.
# Never commit your real .env.local file to git!
# =============================================================================

# -----------------------------------------------------------------------------
# APP / DEPLOYMENT
# -----------------------------------------------------------------------------

# Base URL for the app (used for SEO, share links, auth redirects)
# Example: https://mnwhile-flowkit.vercel.app
VITE_APP_URL=

# -----------------------------------------------------------------------------
# SUPABASE (Auth + PostgreSQL)
# -----------------------------------------------------------------------------

# Public browser-safe Supabase URL and anon key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only service role key (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct database URL for Supabase CLI / local tooling
DATABASE_URL=

# -----------------------------------------------------------------------------
# CLOUDFLARE R2 (Export storage)
# -----------------------------------------------------------------------------

# Server-only credentials for api/upload-export.ts
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Public R2 base URL used by client helpers for display/download links
VITE_R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------

# Optional Sentry browser DSN for production error monitoring
VITE_SENTRY_DSN=

# Optional PostHog analytics
VITE_ENABLE_ANALYTICS=false
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# AI PROVIDERS (optional, users can also paste keys in Settings → AI)
# -----------------------------------------------------------------------------

# Google Gemini — https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Anthropic Claude — https://console.anthropic.com/settings/keys
VITE_CLAUDE_API_KEY=

# Groq — https://console.groq.com/keys
VITE_GROQ_API_KEY=

# NVIDIA NIM — https://build.nvidia.com/
VITE_NVIDIA_API_KEY=

# Cerebras — https://cloud.cerebras.ai/
VITE_CEREBRAS_API_KEY=

# Mistral AI — https://console.mistral.ai/api-keys/
VITE_MISTRAL_API_KEY=

# Custom / Self-hosted OpenAI-compatible endpoint
VITE_CUSTOM_AI_BASE_URL=
VITE_CUSTOM_AI_API_KEY=
VITE_CUSTOM_AI_MODEL=
