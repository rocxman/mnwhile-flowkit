---
import Layout from '../components/Layout.astro';
---

<Layout
  title="OpenFlowKit — Local-First AI Diagramming"
  description="The open-source, local-first diagramming tool with AI-powered generation. No signup required. Your data stays on your device."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="badge">Open Source · Local-First · Free Forever</div>
      <h1>Diagram anything.<br /><span class="accent">No account. No cloud.</span></h1>
      <p class="subtitle">
        OpenFlowKit is an AI-powered diagramming tool that runs entirely in your browser.
        Describe what you need — flowcharts, architecture diagrams, sequence diagrams — and
        watch it appear. All data stays on your device.
      </p>
      <div class="cta-group">
        <a href="https://app.openflowkit.com" class="btn-primary">Open the App →</a>
        <a href="https://docs.openflowkit.com" class="btn-secondary">Read the Docs</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <h2>Everything you need. Nothing you don't.</h2>
      <div class="grid">
        <div class="card">
          <div class="icon">🤖</div>
          <h3>AI Generation</h3>
          <p>Describe your diagram in plain English and OpenFlowKit builds it for you using your own API key — no middleman, no usage fees.</p>
        </div>
        <div class="card">
          <div class="icon">🔒</div>
          <h3>Fully Local</h3>
          <p>All diagrams, history, and settings live in your browser's local storage. Nothing is sent to our servers.</p>
        </div>
        <div class="card">
          <div class="icon">⚡</div>
          <h3>Instant Start</h3>
          <p>No signup, no install. Open the app and start diagramming. Works offline after first load.</p>
        </div>
        <div class="card">
          <div class="icon">🎨</div>
          <h3>Smart Layout</h3>
          <p>Auto-arrange complex graphs with ELK-powered smart layout. Hierarchical, force-directed, radial — pick your style.</p>
        </div>
        <div class="card">
          <div class="icon">📖</div>
          <h3>OpenFlow DSL</h3>
          <p>Write diagrams as code with the OpenFlow DSL. Git-friendly, human-readable, fully reversible.</p>
        </div>
        <div class="card">
          <div class="icon">🔁</div>
          <h3>Playback & History</h3>
          <p>Step through every edit with visual playback. Export as animated GIF or PNG sequence to share your thought process.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Open Source -->
  <section class="oss">
    <div class="container narrow">
      <h2>Free. Open. Forever.</h2>
      <p>
        OpenFlowKit is MIT-licensed and developed in the open. No premium tier, no paywalled features.
        If you find it useful, star the repo or contribute a fix.
      </p>
      <a href="https://github.com/Vrun-design/openflowkit" class="btn-secondary">View on GitHub</a>
    </div>
  </section>
</Layout>
